# zhiweitong — 本地/部署环境变量骨架
# 用法：复制为 `.env` 后按需取消注释并填写（`.env` 已在 .gitignore，勿提交密钥）
# 说明与路径约定：`docs/ops-runbook.md`、`config/settings.py`、`cli/main.py`

# ---------------------------------------------------------------------------
# State（SQLAlchemy 异步）。相对路径相对于「启动进程的当前工作目录」。
# 缺省：sqlite+aiosqlite:///./var/zhiweitong.db
# ---------------------------------------------------------------------------
# ZHIWEITONG_DATABASE_URL=sqlite+aiosqlite:///./var/zhiweitong.db
# 产线建议绝对路径，例如：
# ZHIWEITONG_DATABASE_URL=sqlite+aiosqlite:////var/lib/zhiweitong/zhiweitong.db

# ---------------------------------------------------------------------------
# Redis（总线/缓存预留）
# 缺省：redis://localhost:6379/0
# ---------------------------------------------------------------------------
# ZHIWEITONG_REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# LLM（Orchestrator 等）。密钥勿入库、勿进截图。
# ---------------------------------------------------------------------------
# ZHIWEITONG_LLM_API_KEY=
# 缺省：https://api.openai.com/v1
# ZHIWEITONG_LLM_BASE_URL=https://api.openai.com/v1

# ---------------------------------------------------------------------------
# CLI：`promote-preview` / `promote-apply` / `create-skill` 等
# ---------------------------------------------------------------------------
# 仓库根目录（可选；多 worktree 或测试时常用）
# ZHIWEITONG_PROJECT_ROOT=/path/to/zhiweitong

# Chroma 持久化目录（可选；未设时用 <PROJECT_ROOT>/var/chroma）
# ZHIWEITONG_CHROMA_PATH=/path/to/var/chroma
